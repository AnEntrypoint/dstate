{
  "name": "adaptogen",
  "version": "0.2.0",
  "description": "Agent-owned DAG+FSM state store: durable memory and transition policy in one event-sourced, in-memory graph with soft/hard enforcement. Vendor your own state machine as a JSON spec; persists to a portable JSON bundle, no database.",
  "type": "module",
  "module": "src/index.js",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "adaptogen": "src/cli.js"
  },
  "files": [
    "src",
    "examples",
    "skills",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnEntrypoint/adaptogen.git"
  },
  "homepage": "https://github.com/AnEntrypoint/adaptogen#readme",
  "bugs": {
    "url": "https://github.com/AnEntrypoint/adaptogen/issues"
  },
  "scripts": {
    "test": "bun test.js",
    "bench": "bun run bench/bench.js",
    "cli": "bun run src/cli.js"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.1.0"
  },
  "keywords": [
    "agent",
    "state-machine",
    "fsm",
    "dag",
    "event-sourcing",
    "memory",
    "policy",
    "in-memory",
    "portable"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
